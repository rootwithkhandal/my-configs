alias python="python3"
alias py="python3"
alias pip="pip3"

alias spy="python3 -m venv .venv && source .venv/bin/activate"
alias spyhome="python3 -m venv $HOME/.pyenv && source $HOME/.pyenv/bin/activate"

alias pip-install="pip3 install"
alias pip-update="pip3 install --upgrade"
alias pip-freeze="pip3 freeze"
alias pip-list="pip3 list"

alias serve="python3 -m http.server"
alias pyserver="python3 -m http.server 4445"
