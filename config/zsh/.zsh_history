: 1775729254:0;python3 << 'EOF'\
from forensiq.modules.ram_acquisition import RAMAcquirer\
from forensiq.core.config import CaseConfig\
from forensiq.core.chain_of_custody import ChainOfCustody\
from pathlib import Path\
import tempfile\
\
# Create a temporary directory for testing\
with tempfile.TemporaryDirectory() as tmpdir:\
    # Create test config\
    config = CaseConfig(\
        case="test_case",\
        examiner="test_examiner",\
        evidence_dir=Path(tmpdir)\
    )\
    \
    # Create chain of custody\
    coc = ChainOfCustody(config)\
    \
    # Create tool map\
    tool_map = {\
        "insmod": False,\
        "WinPmem": False,\
        "procdump64": False,\
        "osxpmem": False\
    }\
    \
    # Instantiate RAMAcquirer\
    acquirer = RAMAcquirer(\
        config=config,\
        tool_map=tool_map,\
        coc=coc,\
        os_name="linux"\
    )\
    \
    print("??? RAMAcquirer instantiated successfully")\
    print(f"??? OS name: {acquirer.os_name}")\
    print(f"??? Config case: {acquirer.config.case}")\
    print(f"??? Tool map: {acquirer.tool_map}")\
    \
    # Test that acquire method exists and has correct signature\
    import inspect\
    sig = inspect.signature(acquirer.acquire)\
    params = list(sig.parameters.keys())\
    print(f"??? acquire() parameters: {params}")
: 1775729261:0;source .venv/bin/activate
: 1775729275:0;python3 << 'EOF'\
from forensiq.modules.ram_acquisition import RAMAcquirer\
from forensiq.core.config import CaseConfig\
from forensiq.core.chain_of_custody import ChainOfCustody\
from pathlib import Path\
import tempfile\
\
# Create a temporary directory for testing\
with tempfile.TemporaryDirectory() as tmpdir:\
    # Create test config\
    config = CaseConfig(\
        case="test_case",\
        examiner="test_examiner",\
        evidence_dir=Path(tmpdir)\
    )\
    \
    # Create chain of custody\
    coc = ChainOfCustody(config)\
    \
    # Create tool map\
    tool_map = {\
        "insmod": False,\
        "WinPmem": False,\
        "procdump64": False,\
        "osxpmem": False\
    }\
    \
    # Instantiate RAMAcquirer\
    acquirer = RAMAcquirer(\
        config=config,\
        tool_map=tool_map,\
        coc=coc,\
        os_name="linux"\
    )\
    \
    print("??? RAMAcquirer instantiated successfully")\
    print(f"??? OS name: {acquirer.os_name}")\
    print(f"??? Config case: {acquirer.config.case}")\
    print(f"??? Tool map: {acquirer.tool_map}")\
