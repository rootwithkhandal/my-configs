from pathlib import Path\
from forensiq.core.config import CaseConfig\
\
# Test validation - empty case\
try:\
    config = CaseConfig(\
        case='',\
        examiner='Test Examiner',\
        evidence_dir=Path('/tmp/test-evidence')\
    )\
    print('ERROR: Should have raised ValueError for empty case')\
except ValueError as e:\
    print(f'??? Correctly rejected empty case: {e}')\
\
# Test validation - invalid log level\
try:\
    config = CaseConfig(\
        case='TEST-001',\
        examiner='Test Examiner',\
        evidence_dir=Path('/tmp/test-evidence'),\
        log_level='INVALID'\
    )\
    print('ERROR: Should have raised ValueError for invalid log level')\
except ValueError as e:\
    print(f'??? Correctly rejected invalid log level: {e}')\
\
# Test validation - negative dashboard refresh\
try:\
    config = CaseConfig(\
        case='TEST-001',\
        examiner='Test Examiner',\
        evidence_dir=Path('/tmp/test-evidence'),\
        dashboard_refresh=-1.0\
    )\
    print('ERROR: Should have raised ValueError for negative dashboard_refresh')\
except ValueError as e:\
    print(f'??? Correctly rejected negative dashboard_refresh: {e}')\
\
print('\\nAll validation tests passed!')\
"
