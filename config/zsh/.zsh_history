from pathlib import Path\
from forensiq.core.config import CaseConfig\
from forensiq.core.chain_of_custody import ChainOfCustody\
from forensiq.modules.yara_scan import YARAScanner\
import tempfile, os\
\
with tempfile.TemporaryDirectory() as tmpdir:\
    config = CaseConfig(case='test', examiner='analyst', evidence_dir=Path(tmpdir))\
    coc = ChainOfCustody(config)\
    scanner = YARAScanner(config, coc)\
    print('YARAScanner instantiated OK')\
    print('Rules loaded:', scanner.rules is not None)\
    \
    # Test scan_file on a temp file\
    test_file = Path(tmpdir) / 'test.txt'\
    test_file.write_text('CreateRemoteThread VirtualAlloc GetProcAddress')\
    matches = scanner.scan_file(test_file)\
    print(f'scan_file returned {len(matches)} match(es)')\
    for m in matches:\
        print(f'  rule={m.rule_name}, tags={m.tags}, meta keys={list(m.meta.keys())}')\
    \
    # Test scan_directory\
    dir_results = scanner.scan_directory(Path(tmpdir))\
    print(f'scan_directory returned {len(dir_results)} file(s)')\
    \
    # Test CoC logging\
    scanner.log_coc_event(total_matches=len(matches))\
    print('CoC event logged OK')\
    print('CoC entries:', len(coc.entries))\
"
: 1775734670:0;python -c "\
from pathlib import Path\
from forensiq.core.config import CaseConfig\
from forensiq.core.chain_of_custody import ChainOfCustody\
from forensiq.modules.yara_scan import YARAScanner, YARAMatch\
from ioc.ioc_detector import IOCDetector\
import tempfile\
\
with tempfile.TemporaryDirectory() as tmpdir:\
    config = CaseConfig(case='test', examiner='analyst', evidence_dir=Path(tmpdir))\
    coc = ChainOfCustody(config)\
    scanner = YARAScanner(config, coc)\
    \
    print('Extends IOCDetector:', issubclass(YARAScanner, IOCDetector))\
    print('Rules loaded:', scanner.rules is not None)\
    \
    # scan_file\
    test_file = Path(tmpdir) / 'test.txt'\
    test_file.write_text('CreateRemoteThread VirtualAlloc GetProcAddress')\
    matches = scanner.scan_file(test_file)\
    print(f'scan_file: {len(matches)} match(es)')\
    assert all(isinstance(m, YARAMatch) for m in matches)\
    assert all(m.rule_name and m.tags is not None and m.meta is not None and m.strings is not None for m in matches)\
    \
    # scan_directory\
    dir_results = scanner.scan_directory(Path(tmpdir))\
    assert str(test_file) in dir_results\
    print(f'scan_directory: {len(dir_results)} file(s) covered')\
    \
    # CoC\
    scanner.log_coc_event(total_matches=len(matches))\
    assert coc.entries[-1].event_type == 'YARA_SCAN_COMPLETE'\
    print('All assertions passed')\
"
