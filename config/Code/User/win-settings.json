{
    "workbench.colorTheme": "React Dev Theme (dark)",
    // "workbench.iconTheme": "vscode-icons",
    // "workbench.productIconTheme": "macos-modern",
    "chat.fontFamily": "Cascadia code,Cascadia mono",
    "editor.fontFamily": "Cascadia code,Cascadia mono",
    "editor.fontLigatures": true,
    "editor.fontSize": 14,
    "window.zoomLevel": 1,
    "editor.lineHeight": 0,
    "terminal.integrated.allowInUntrustedWorkspace": true,
    "terminal.integrated.fontFamily": "Cascadia Mono",
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.defaultProfile.windows": "Windows PowerShell",
    "terminal.integrated.defaultProfile.osx": "zsh",
    "chat.mcp.gallery.enabled": true,
    "workbench.startupEditor": "none",
    "window.menuBarVisibility": "compact",
    // "workbench.activityBar.location": "top", // default in kiro
    "workbench.sideBar.location": "right",
    "workbench.statusBar.visible": false,
    "workbench.layoutControl.enabled": true,
    "workbench.list.multiSelectModifier": "alt",
    "security.workspace.trust.untrustedFiles": "open",
    "editor.fontWeight": "500",
    "editor.guides.highlightActiveIndentation": false,
    "editor.parameterHints.enabled": false,
    "editor.inlayHints.enabled": "off",
    "editor.inlineSuggest.enabled": true,
    "editor.codeLens": false,
    "editor.foldingHighlight": false,
    "editor.multiCursorMergeOverlapping": false,
    "editor.formatOnPaste": true,
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.verticalScrollbarSize": 10,
    "editor.scrollbar.horizontalScrollbarSize": 10,
    "editor.wordBasedSuggestions": "matchingDocuments",
    "editor.copyWithSyntaxHighlighting": false,
    "diffEditor.ignoreTrimWhitespace": false,
    "editor.emptySelectionClipboard": false,
    "workbench.editor.enablePreview": false,
    "window.newWindowDimensions": "inherit",
    "editor.multiCursorModifier": "alt",
    "files.trimTrailingWhitespace": true,
    "diffEditor.renderSideBySide": true,
    "editor.snippetSuggestions": "top",
    "editor.detectIndentation": false,
    "window.nativeFullScreen": true,
    "window.restoreFullscreen": true,
    "files.insertFinalNewline": true,
    "files.trimFinalNewlines": true,
    "workbench.editor.showTabs": "multiple",
    "editor.lineNumbers": "relative", // off in kiro
    "editor.guides.indentation": false,
    "breadcrumbs.enabled": false,
    "scm.diffDecorations": "none",
    "editor.hover.delay": 300,
    "editor.hover.enabled": "on",
    "editor.matchBrackets": "never",
    "workbench.tips.enabled": false,
    "editor.colorDecorators": false,
    "git.decorations.enabled": false,
    "editor.selectionHighlight": false,
    "editor.lightbulb.enabled": "off",
    "editor.overviewRulerBorder": false,
    "editor.renderLineHighlight": "none",
    "editor.occurrencesHighlight": "off",
    "problems.decorations.enabled": false,
    "editor.renderControlCharacters": false,
    "editor.hideCursorInOverviewRuler": true,
    "editor.gotoLocation.multipleReferences": "goto",
    "editor.gotoLocation.multipleDefinitions": "goto",
    "editor.gotoLocation.multipleDeclarations": "goto",
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "editor.gotoLocation.multipleImplementations": "goto",
    "editor.gotoLocation.multipleTypeDefinitions": "goto",
    "workbench.colorCustomizations": {},
    "workbench.tree.enableStickyScroll": true,
    "workbench.editor.closeEmptyGroups": false,
    "workbench.tree.indent": 8,
    "workbench.tree.renderIndentGuides": "onHover",
    "workbench.editor.editorActionsLocation": "titleBar",
    "workbench.commandPalette.experimental.enableNaturalLanguageSearch": true,
    "workbench.commandPalette.experimental.suggestCommands": false,
    "window.titleSeparator": " | ",
    "window.autoDetectHighContrast": false,
    "window.newWindowProfile": "Default",
    "workbench.editor.empty.hint": "hidden",
    "files.autoSave": "afterDelay",
    "editor.wordWrap": "on",
    "editor.smoothScrolling": true,
    "editor.mouseWheelZoom": true,
    "editor.unicodeHighlight.nonBasicASCII": false,
    "editor.minimap.enabled": false,
    "editor.linkedEditing": true,
    "editor.glyphMargin": false,
    "editor.padding.bottom": 14,
    "editor.padding.top": 14,
    "terminal.integrated.gpuAcceleration": "on",
    "terminal.integrated.enableImages": true,
    "terminal.integrated.fontSize": 14,
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.cursorStyleInactive": "line",
    "terminal.integrated.cursorWidth": 2,
    "terminal.integrated.cursorBlinking": true,
    "terminal.integrated.lineHeight": 1,
    "terminal.integrated.autoReplies": {
        "Terminate batch job (Y/N)": "Y\r",
        "Terminate batch job (Y/n)": "Y\r"
    },
    // Here custom styles and script to modify VS Code
    // "vscode_custom_css.imports": [
    //     "file:///C:/Users/xphantom/Documents/vscode"
    // ]
    // Here language specific settings
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.codeActionsOnSave": {
            "source.fixAll": "explicit"
        },
        "editor.rulers": [
            {
                "column": 72,
                "color": "#684e4e"
            },
            {
                "column": 79,
                "color": "#4b5c59"
            }
        ]
    },
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[json]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "yaml.schemas": {},
    // Here git settings
    "git.autofetch": true,
    "git.confirmSync": false,
    "scm.defaultViewMode": "tree",
    "explorer.autoReveal": false,
    "explorer.compactFolders": false,
    "explorer.openEditors.visible": 1,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmPasteNative": false,
    "explorer.confirmDelete": false,
    "explorer.fileNesting.patterns": {
        "*.ts": "${capture}.js",
        "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
        "*.jsx": "${capture}.js",
        "*.tsx": "${capture}.ts",
        "tsconfig.json": "tsconfig.*.json",
        "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
        "Cargo.toml": "Cargo.lock",
        "*.sqlite": "${capture}.${extname}-*",
        "*.db": "${capture}.${extname}-*"
    },
    // Here security settings
    // Here experimental settings
    "indentRainbow.indicatorStyle": "light",
    "indentRainbow.lightIndicatorStyleLineWidth": 1,
    "indentRainbow.colors": [
        "rgba(255,255,64,0.3)",
        "rgba(127,255,127,0.3)",
        "rgba(255,127,255,0.3)",
        "rgba(79,236,236,0.3)"
    ],
    "glassit.alpha": 255,
    "resmon.show.cputemp": true,
    "apc.stylesheet": {
        ".quick-input-widget": {
            "transform": "translateY(-50%) !important",
            "top": "50% !important"
        }
    },
    "database-client.autoSync": true,
}